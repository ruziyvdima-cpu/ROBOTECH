rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email_verified == true && request.auth.token.email == 'ruziyvdima@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Phase 4: Entity Validators
    function isValidProduct(data) {
      return data.keys().hasAll(['name_uz', 'name_en', 'name_ru', 'description_uz', 'description_en', 'description_ru', 'price', 'stock', 'image', 'category', 'updatedAt'])
        && data.keys().size() == 11
        && data.name_uz is string && data.name_uz.size() <= 200
        && data.name_en is string && data.name_en.size() <= 200
        && data.name_ru is string && data.name_ru.size() <= 200
        && data.description_uz is string && data.description_uz.size() <= 2000
        && data.description_en is string && data.description_en.size() <= 2000
        && data.description_ru is string && data.description_ru.size() <= 2000
        && data.price is number && data.price >= 0
        && data.stock is number && data.stock >= 0
        && data.image is string && data.image.size() <= 1000
        && data.category is string && data.category.size() <= 50
        && data.updatedAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'customerInfo', 'status', 'createdAt'])
        && data.keys().size() == 6
        && data.userId == request.auth.uid
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.customerInfo is map
        && data.status in ['pending', 'completed', 'cancelled']
        && data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'name'])
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 254
        && data.role in ['user', 'admin']
        && data.name is string && data.name.size() <= 100;
    }

    // Collections
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['completed', 'cancelled']
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (incoming().role == 'user' || request.auth.token.email == 'ruziyvdima@gmail.com');
      allow update: if (isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name']))) && isValidUser(incoming());
    }
  }
}
